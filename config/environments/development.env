# ============================================
# Development Environment Configuration
# ============================================
ENVIRONMENT=development

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=auth-db-dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password_123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=development_jwt_secret_key_change_in_production
JWT_ISSUER=auth-api-dev
JWT_AUDIENCE=auth-client-dev
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ============================================
# Application Configuration
# ============================================
APP_NAME=Auth API (Development)
APP_VERSION=1.0.0-dev
HOST=0.0.0.0
PORT=8000
APP_URL=http://localhost:3000

# ============================================
# Google OAuth (Development)
# ============================================
GOOGLE_CLIENT_ID=your-dev-google-client-id

# ============================================
# Email Configuration (Development)
# ============================================
EMAIL_FROM=dev@auth-api.local
RESEND_API_KEY=

# ============================================
# Rate Limiting Configuration
# ============================================
RATE_LIMITER_STORAGE=memory://
RATE_LIMITER_DEFAULT_LIMIT=10000/hour

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ============================================
# Security Configuration
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
