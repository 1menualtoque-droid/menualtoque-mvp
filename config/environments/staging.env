# ============================================
# Staging Environment Configuration
# ============================================
ENVIRONMENT=staging

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=auth-db-staging
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_HOST=${POSTGRES_HOST}
POSTGRES_PORT=5432
DATABASE_URL=${DATABASE_URL}

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=${JWT_SECRET}
JWT_ISSUER=auth-api-staging
JWT_AUDIENCE=auth-client-staging
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# ============================================
# Application Configuration
# ============================================
APP_NAME=Auth API (Staging)
APP_VERSION=${APP_VERSION}
HOST=0.0.0.0
PORT=8000
APP_URL=${APP_URL}

# ============================================
# Google OAuth (Staging)
# ============================================
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}

# ============================================
# Email Configuration (Staging)
# ============================================
EMAIL_FROM=${EMAIL_FROM}
RESEND_API_KEY=${RESEND_API_KEY}

# ============================================
# Rate Limiting Configuration
# ============================================
RATE_LIMITER_STORAGE=${RATE_LIMITER_STORAGE}
RATE_LIMITER_DEFAULT_LIMIT=5000/hour

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Security Configuration
# ============================================
CORS_ORIGINS=${CORS_ORIGINS}
