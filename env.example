# ============================================
# Environment Configuration
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=auth-db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=
JWT_ISSUER=auth-api
JWT_AUDIENCE=auth-client
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# ============================================
# Application Configuration
# ============================================
# Application name and version
APP_NAME=Auth API
APP_VERSION=1.0.0

# Server configuration
HOST=0.0.0.0
PORT=8000

# Frontend application URL (used for CORS and email links)
APP_URL=http://localhost:3000

# ============================================
# Google OAuth
# ============================================
# Google OAuth2 Client ID for authentication
# Get this from Google Cloud Console
GOOGLE_CLIENT_ID=

# ============================================
# Email Configuration
# ============================================
# Email sender address
EMAIL_FROM=noreply@example.com

# Resend API Key (optional, for email sending)
# Get this from https://resend.com
RESEND_API_KEY=

# ============================================
# Rate Limiting Configuration
# ============================================
# Rate limiter storage backend
# Use "memory://" for single instance (recommended for development)
# Use "redis://..." for production with multiple instances
RATE_LIMITER_STORAGE=memory://

# Default rate limit for all endpoints (format: "number/period")
# Examples: "1000/hour", "100/minute", "50/second"
RATE_LIMITER_DEFAULT_LIMIT=1000/hour

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Security Configuration
# ============================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
